{
  "name": "abgeordnetenwatch-api-spec",
  "version": "0.1.0",
  "type": "module",
  "dependencies": {
    "@typespec/compiler": "^1.9.0",
    "@typespec/http": "^1.9.1",
    "@typespec/openapi": "^1.9.0",
    "@typespec/openapi3": "^1.9.0",
    "@typespec/versioning": "^0.79.0"
  },
  "private": true,
  "packageManager": "yarn@4.13.0",
  "scripts": {
    "watch": "tsp compile main.tsp --watch",
